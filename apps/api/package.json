{
  "name": "@zcy/api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "kill-port 3000 && nest start --watch",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "typeorm": "cross-env TS_NODE_TRANSPILE_ONLY=true TS_NODE_PROJECT=tsconfig.json ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "node scripts/migration.mjs generate",
    "migration:create": "node scripts/migration.mjs create",
    "migration:run": "node scripts/migration.mjs run",
    "migration:revert": "node scripts/migration.mjs revert",
    "migration:show": "node scripts/migration.mjs show",
    "migration:sync": "node scripts/migration.mjs generate && node scripts/migration.mjs run",
    "seed:demo": "cross-env RUN_SEED=true TS_NODE_TRANSPILE_ONLY=true ts-node -r tsconfig-paths/register src/db/seeds/seed-demo.ts",
    "test:flow": "node scripts/test-flow.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.18",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "mysql2": "^3.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.2",
    "@types/passport-jwt": "^4.0.1",
    "cross-env": "^10.1.0",
    "kill-port": "^2.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
